# -------------------
# | Terraform files |
# -------------------
# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Variables files
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# Execution plan files
*.tfplan

# Don't include temporal plan file created by ansible
apply_plan

# -----------------------
# | Task file overrides |
# -----------------------
Taskfile.yml
taskfile.yml
Taskfile.yaml
taskfile.yaml

# ---------------------------
# | IDE configuration files |
# ---------------------------
# VS Code
.vscode/

# IntelliJ IDEA
.idea/
*.iml

# Eclipse
.project
.classpath
.settings/

# Sublime Text
*.sublime-project
*.sublime-workspace

# ---------------
# | Misc. files |
# ---------------
# Log files
# For example crash log files
*.log

# Lambda build artifacts
builds/
__pycache__/
*.zip
.tox

# Local macos file
.DS_Store
